}

        }
    }

    if (!expect(TOKEN_RIGHT_BRACE, E_PARSE_02, "}", "missing '}'",
                "example: {\"a\": 1, \"b\": 2}")) {
        free(keys);
        free(vals);
        return NULL;
    }

    skip_separators();
    return new_dict_node(keys, vals, count);
