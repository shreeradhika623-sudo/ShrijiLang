mavi total = 0
mavi i = 1
mavi j = 2
mavi flag = 1

agar flag {
    total = (10 + 20) * (3 + 1) - 15
}

agar 1 {
    i = 1
    agar i < 100 {
        agar i % 2 {
            total = total + i * 3 - 1
        }
        i = i + 1
    }
}

agar 1 {
    j = 1
    agar j < 200 {
        total = (total * 7 + j * 11 - 9) / 3
        agar total % 5 {
            total = total + j / 2
        }
        j = j + 1
    }
}

mavi a = 1
mavi b = 2
mavi c = 3
mavi d = 4

agar 1 {
    agar 1 {
        agar a < 50 {
            a = a + b * c - d
            d = d + 1
        }
    }
}

mavi k = 0
agar 1 {
    k = k + 1
    agar k < 100 {
        agar 1 { }
    }
}
