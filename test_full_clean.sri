mavi a = 10
mavi b = 20
mavi c = 5

mavi sum = a + b
mavi diff = b - a
mavi prod = a * c
mavi div = b / c

mavi isSmall = a < b
mavi isBig = b > a
mavi isEqual = a == c
mavi isNotEqual = a != c

mavi flag = nahi false
mavi flag2 = nahi isEqual

agar a < b {
    mavi inside1 = a + b
}

agar a > b {
    mavi result1 = 999
} warna {
    mavi result1 = 111
}

agar a < b {
    agar b > c {
        mavi deep = a * b
    } warna {
        mavi deep = 0
    }
}

mavi complex1 = (a + b) * c
mavi complex2 = (b - a) + (c * 2)
mavi complex3 = (a + b + c) * (a - c)

agar nahi (a == b) {
    mavi logicTest = 1
} warna {
    mavi logicTest = 0
}

mavi finalA = a
mavi finalB = b
mavi finalC = c
