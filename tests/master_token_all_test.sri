# ---------- PART A: EXECUTABLE CORE ----------

mavi a = 10
mavi b = 20

bolo "Start master test"

agar a < b {
    bolo "a chhota hai b se"
} warna {
    bolo "a bada ya barabar hai b ke"
}

mavi result = 0

agar b > a {
    result = 1
} warna {
    result = 0
}

bolo "Core control-flow complete"


